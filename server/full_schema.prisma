model Categoria {
  id               Int          @id @default(autoincrement())
  categoria_pai_id Int?
  nome             String       @db.VarChar(255)
  slug             String       @db.VarChar(255)
  criado_em        DateTime?    @default(now()) @db.DateTime(0)
  acabamentos      Acabamento[]
  categoria_pai    Categoria?   @relation("Subcategorias", fields: [categoria_pai_id], references: [id], onUpdate: NoAction, map: "categorias_ibfk_1")
  subcategorias    Categoria[]  @relation("Subcategorias")
  produtos         Produto[]

  @@index([categoria_pai_id], map: "categoria_pai_id")
  @@map("categorias")
}

model Produto {
  id                 Int          @id @default(autoincrement())
  categoria_id       Int?
  nome               String       @db.VarChar(255)
  descricao          String?      @db.Text
  ncm                String?      @db.VarChar(50)
  sku                String?      @db.VarChar(100)
  preco_venda        Decimal      @db.Decimal(10, 2)
  unidade_medida     String       @db.VarChar(20)
  largura_maxima     Decimal?     @db.Decimal(10, 2)
  altura_maxima      Decimal?     @db.Decimal(10, 2)
  comprimento_maximo Decimal?     @db.Decimal(10, 2)
  status             Boolean?     @default(true)
  criado_em          DateTime?    @default(now()) @db.DateTime(0)
  acabamentos        Acabamento[]
  categoria          Categoria?   @relation(fields: [categoria_id], references: [id], onUpdate: NoAction, map: "produtos_ibfk_1")

  @@index([categoria_id], map: "categoria_id")
  @@map("produtos")
}

model Acabamento {
  id             Int        @id @default(autoincrement())
  categoria_id   Int?
  produto_id     Int?
  nome           String     @db.VarChar(255)
  tipo_acrescimo String     @db.VarChar(20)
  valor          Decimal    @db.Decimal(10, 2)
  ativo          Boolean?   @default(false)
  categoria      Categoria? @relation(fields: [categoria_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "acabamentos_ibfk_1")
  produto        Produto?   @relation(fields: [produto_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "acabamentos_ibfk_2")

  @@index([categoria_id], map: "categoria_id")
  @@index([produto_id], map: "produto_id")
  @@map("acabamentos")
}

